{
  "mcp": {
    "github-discovery": {
      "type": "local",
      "command": ["uvx", "github-discovery", "mcp", "serve", "--transport", "stdio"],
      "environment": {
        "GHDISC_GITHUB_TOKEN": "{env:GITHUB_TOKEN}",
        "GHDISC_ASSESSMENT_NANOGPT_API_KEY": "{env:GHDISC_ASSESSMENT_NANOGPT_API_KEY}",
        "GHDISC_SESSION_BACKEND": "sqlite",
        "GHDISC_MCP_TRANSPORT": "stdio"
      }
    }
  }
}
